{
  "rules": {
    ".read": false,
    ".write": false,
    "sessions": {
      "$sessionId": {
        "events": {
          ".read": true,
          ".write": true,
          "$eventId": {
            ".validate": "newData.hasChildren(['type', '_clientId', '_ts'])"
          }
        }
      }
    }
  }
}
